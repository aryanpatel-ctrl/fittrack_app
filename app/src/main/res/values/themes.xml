<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme -->
    <style name="Theme.FitTrackPro" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_variant</item>
        <item name="colorOnSecondary">@color/text_on_secondary</item>
        <!-- Background and surface -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <!-- Error color -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/white</item>
        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <!-- Window settings -->
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
        <!-- Material component styles -->
        <item name="materialCardViewStyle">@style/Widget.FitTrackPro.CardView</item>
        <item name="materialButtonStyle">@style/Widget.FitTrackPro.Button</item>
        <item name="chipStyle">@style/Widget.FitTrackPro.Chip</item>
    </style>

    <!-- Splash Screen Theme -->
    <style name="Theme.FitTrackPro.Splash" parent="Theme.FitTrackPro">
        <item name="android:windowBackground">@color/primary</item>
    </style>

    <!-- Tracking Activity Theme (Full screen for map) -->
    <style name="Theme.FitTrackPro.Tracking" parent="Theme.FitTrackPro">
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <!-- Onboarding Theme -->
    <style name="Theme.FitTrackPro.Onboarding" parent="Theme.FitTrackPro">
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>

    <!-- Legacy theme for compatibility -->
    <style name="Theme.MyApplication" parent="Theme.FitTrackPro" />

    <!-- ==================== CARD VIEW STYLES ==================== -->
    <style name="Widget.FitTrackPro.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/surface</item>
    </style>

    <style name="Widget.FitTrackPro.CardView.Outlined" parent="Widget.Material3.CardView.Outlined">
        <item name="cardCornerRadius">16dp</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- ==================== BUTTON STYLES ==================== -->
    <style name="Widget.FitTrackPro.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.FitTrackPro.Button.Primary" parent="Widget.FitTrackPro.Button">
        <item name="backgroundTint">@color/primary</item>
    </style>

    <style name="Widget.FitTrackPro.Button.Accent" parent="Widget.FitTrackPro.Button">
        <item name="backgroundTint">@color/accent</item>
    </style>

    <style name="Widget.FitTrackPro.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="strokeColor">@color/primary</item>
        <item name="android:textColor">@color/primary</item>
    </style>

    <style name="Widget.FitTrackPro.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/primary</item>
    </style>

    <style name="Widget.FitTrackPro.Button.Large" parent="Widget.FitTrackPro.Button">
        <item name="cornerRadius">28dp</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- ==================== CHIP STYLES ==================== -->
    <style name="Widget.FitTrackPro.Chip" parent="Widget.Material3.Chip.Assist">
        <item name="chipCornerRadius">16dp</item>
        <item name="chipBackgroundColor">@color/primary_surface</item>
        <item name="android:textColor">@color/primary</item>
    </style>

    <style name="Widget.FitTrackPro.Chip.Filter" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">16dp</item>
    </style>

    <!-- ==================== TEXT INPUT STYLES ==================== -->
    <style name="Widget.FitTrackPro.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/primary</item>
    </style>

    <!-- ==================== TEXT STYLES ==================== -->
    <style name="TextAppearance.FitTrackPro.Headline1" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.FitTrackPro.Headline2" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.FitTrackPro.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.FitTrackPro.Subtitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.FitTrackPro.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.FitTrackPro.BodySmall" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.FitTrackPro.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/text_hint</item>
    </style>

    <style name="TextAppearance.FitTrackPro.Label" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- ==================== STAT VALUE STYLES ==================== -->
    <style name="TextAppearance.FitTrackPro.StatValue" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.FitTrackPro.StatLabel" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- ==================== BOTTOM NAVIGATION ==================== -->
    <style name="Widget.FitTrackPro.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>

    <!-- ==================== SHAPE APPEARANCES ==================== -->
    <style name="ShapeAppearance.FitTrackPro.SmallComponent" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ShapeAppearance.FitTrackPro.MediumComponent" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeAppearance.FitTrackPro.LargeComponent" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <style name="CircleImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- ==================== TOOLBAR STYLES ==================== -->
    <style name="Widget.FitTrackPro.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="titleTextColor">@color/white</item>
        <item name="android:background">@color/primary</item>
    </style>

    <style name="Widget.FitTrackPro.Toolbar.Transparent" parent="Widget.Material3.Toolbar">
        <item name="titleTextColor">@color/text_primary</item>
        <item name="android:background">@android:color/transparent</item>
    </style>

    <!-- ==================== PROGRESS BAR STYLES ==================== -->
    <style name="Widget.FitTrackPro.ProgressBar" parent="Widget.Material3.LinearProgressIndicator">
        <item name="trackColor">@color/progress_background</item>
        <item name="indicatorColor">@color/primary</item>
        <item name="trackCornerRadius">4dp</item>
    </style>

    <style name="Widget.FitTrackPro.CircularProgress" parent="Widget.Material3.CircularProgressIndicator">
        <item name="trackColor">@color/progress_background</item>
        <item name="indicatorColor">@color/primary</item>
    </style>

    <!-- ==================== DIALOG STYLES ==================== -->
    <style name="Theme.FitTrackPro.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.FitTrackPro.MediumComponent</item>
    </style>

    <!-- ==================== SNACKBAR STYLES ==================== -->
    <style name="Widget.FitTrackPro.Snackbar" parent="Widget.Material3.Snackbar">
        <item name="android:background">@color/text_primary</item>
    </style>
</resources>
