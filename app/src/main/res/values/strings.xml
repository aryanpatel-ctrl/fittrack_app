    <!-- ==================== MOTIVATIONAL QUOTES ==================== -->
    <string name="quote_1">The only bad workout is the one that didn\'t happen.</string>
    <string name="quote_2">Your body can stand almost anything. It\'s your mind you have to convince.</string>
    <string name="quote_3">Fitness is not about being better than someone else. It\'s about being better than you used to be.</string>
    <string name="quote_4">The pain you feel today will be the strength you feel tomorrow.</string>
    <string name="quote_5">Don\'t stop when you\'re tired. Stop when you\'re done.</string>
    <string name="quote_6">Success starts with self-discipline.</string>
    <string name="quote_7">The hard days are what make you stronger.</string>
    <string name="quote_8">Every workout is progress, no matter how small.</string>
    <string name="quote_9">Your only limit is you.</string>
    <string name="quote_10">Champions train, losers complain.</string>
    <string name="quote_11">Sweat is just fat crying.</string>
    <string name="quote_12">The difference between try and triumph is a little umph.</string>
    <string name="quote_13">Wake up with determination. Go to bed with satisfaction.</string>
    <string name="quote_14">It\'s not about having time. It\'s about making time.</string>
    <string name="quote_15">Sore today, strong tomorrow.</string>
    <string name="quote_16">You don\'t have to be extreme, just consistent.</string>
    <string name="quote_17">The best project you\'ll ever work on is you.</string>
    <string name="quote_18">One day or day one. You decide.</string>
    <string name="quote_19">Progress, not perfection.</string>
    <string name="quote_20">Exercise is a celebration of what your body can do.</string>
    <string name="daily_motivation">Daily Motivation</string>

    <!-- ==================== FITNESS TIPS ==================== -->
    <string name="tip_category_running">Running Tip</string>
    <string name="tip_category_nutrition">Nutrition Tip</string>
    <string name="tip_category_recovery">Recovery Tip</string>
    <string name="tip_category_general">Pro Tip</string>

    <string name="tip_running_1">Land midfoot when running to reduce impact and improve efficiency.</string>
    <string name="tip_running_2">Keep your arms at 90 degrees and swing them forward, not across your body.</string>
    <string name="tip_running_3">Increase your weekly mileage by no more than 10% to prevent injury.</string>
    <string name="tip_running_4">Run easy on easy days. 80% of your runs should be at conversational pace.</string>
    <string name="tip_running_5">Cadence matters! Aim for 170-180 steps per minute for optimal efficiency.</string>

    <string name="tip_nutrition_1">Eat within 30 minutes post-workout to maximize recovery.</string>
    <string name="tip_nutrition_2">Hydrate before you feel thirsty. Aim for half your body weight in ounces daily.</string>
    <string name="tip_nutrition_3">Protein helps rebuild muscle. Include it in every meal.</string>
    <string name="tip_nutrition_4">Complex carbs fuel long workouts. Don\'t skip them on training days!</string>
    <string name="tip_nutrition_5">Pre-workout meal: easy to digest, moderate carbs, low fat, 2-3 hours before.</string>

    <string name="tip_recovery_1">Sleep is when your body repairs. Aim for 7-9 hours nightly.</string>
    <string name="tip_recovery_2">Foam rolling can reduce muscle soreness by 50%.</string>
    <string name="tip_recovery_3">Active recovery days help flush out lactic acid faster than complete rest.</string>
    <string name="tip_recovery_4">Stretching after workouts improves flexibility and reduces injury risk.</string>
    <string name="tip_recovery_5">Listen to your body. Rest when you need it – it\'s part of training.</string>

    <string name="tip_general_1">Consistency beats intensity. Show up every day.</string>
    <string name="tip_general_2">Track your progress weekly, not daily. Trends matter more than fluctuations.</string>
    <string name="tip_general_3">Set SMART goals: Specific, Measurable, Achievable, Relevant, Time-bound.</string>
    <string name="tip_general_4">Find a workout buddy – accountability increases success by 65%.</string>
    <string name="tip_general_5">Celebrate small wins. Every step forward is progress.</string>

