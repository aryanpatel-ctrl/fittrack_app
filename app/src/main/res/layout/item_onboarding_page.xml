<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <!-- Illustration/Icon Container -->
    <FrameLayout
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_marginBottom="48dp">

        <!-- Background Circle -->
        <View
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_onboarding_icon_circle" />

        <!-- Feature Icon -->
        <ImageView
            android:id="@+id/iv_onboarding_icon"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            app:tint="@color/white"
            tools:src="@drawable/ic_running" />

    </FrameLayout>

    <!-- Title -->
    <TextView
        android:id="@+id/tv_onboarding_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:gravity="center"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:textStyle="bold"
        tools:text="Track Your Progress" />

    <!-- Description -->
    <TextView
        android:id="@+id/tv_onboarding_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:alpha="0.9"
        android:gravity="center"
        android:lineSpacingExtra="6dp"
        android:textColor="@color/white"
        android:textSize="16sp"
        tools:text="Monitor every step, every mile, every achievement. Our GPS tracking captures your journey with precision accuracy." />

</LinearLayout>
