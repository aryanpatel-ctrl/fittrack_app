<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <!-- Illustration Container with Badges -->
    <FrameLayout
        android:layout_width="200dp"
        android:layout_height="180dp"
        android:layout_marginBottom="24dp">

        <!-- Background Glow -->
        <View
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_empty_state_achievements" />

        <!-- Badge Stack Animation Style -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="horizontal">

            <!-- Left Badge (Locked) -->
            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="-12dp"
                android:alpha="0.5"
                android:rotation="-10">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_achievement_badge"
                    app:tint="@color/empty_state_icon"
                    android:contentDescription="@null" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_lock"
                    app:tint="@color/text_hint"
                    android:contentDescription="@null" />

            </FrameLayout>

            <!-- Center Badge (Main - Unlockable) -->
            <FrameLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:elevation="8dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_achievement_badge"
                    app:tint="@color/tier_gold"
                    android:contentDescription="@string/empty_achievements_title" />

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_star"
                    app:tint="@color/white"
                    android:contentDescription="@null" />

            </FrameLayout>

            <!-- Right Badge (Locked) -->
            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="-12dp"
                android:alpha="0.5"
                android:rotation="10">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_achievement_badge"
                    app:tint="@color/empty_state_icon"
                    android:contentDescription="@null" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_lock"
                    app:tint="@color/text_hint"
                    android:contentDescription="@null" />

            </FrameLayout>

        </LinearLayout>

        <!-- Sparkle Effects -->
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="20dp"
            android:alpha="0.8"
            android:src="@drawable/ic_sparkle"
            app:tint="@color/xp_gold"
            android:contentDescription="@null" />

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="30dp"
            android:layout_marginBottom="30dp"
            android:alpha="0.6"
            android:src="@drawable/ic_sparkle"
            app:tint="@color/xp_gold"
            android:contentDescription="@null" />

    </FrameLayout>

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:gravity="center"
        android:text="@string/empty_achievements_title"
        android:textColor="@color/text_primary"
        android:textSize="22sp"
        android:textStyle="bold" />

    <!-- Description -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:paddingHorizontal="16dp"
        android:text="@string/empty_achievements_message"
        android:textColor="@color/text_secondary"
        android:textSize="15sp" />

    <!-- CTA Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_empty_state_cta"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:paddingHorizontal="32dp"
        android:text="@string/empty_achievements_cta"
        android:textAllCaps="false"
        android:textSize="15sp"
        app:backgroundTint="@color/tier_gold"
        app:cornerRadius="24dp"
        app:icon="@drawable/ic_play"
        app:iconGravity="textStart"
        app:iconPadding="8dp" />

    <!-- Achievement Tiers Preview -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- Bronze Tier -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_achievement_badge"
                app:tint="@color/tier_bronze"
                android:contentDescription="@string/tier_bronze" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/tier_bronze"
                android:textColor="@color/tier_bronze"
                android:textSize="11sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Silver Tier -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_achievement_badge"
                app:tint="@color/tier_silver"
                android:contentDescription="@string/tier_silver" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/tier_silver"
                android:textColor="@color/tier_silver"
                android:textSize="11sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Gold Tier -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_achievement_badge"
                app:tint="@color/tier_gold"
                android:contentDescription="@string/tier_gold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/tier_gold"
                android:textColor="@color/tier_gold"
                android:textSize="11sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Platinum Tier -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_achievement_badge"
                app:tint="@color/xp_purple"
                android:contentDescription="@string/tier_platinum" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/tier_platinum"
                android:textColor="@color/xp_purple"
                android:textSize="11sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
