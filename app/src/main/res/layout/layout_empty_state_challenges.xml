<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <!-- Illustration Container -->
    <FrameLayout
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_marginBottom="24dp">

        <!-- Background Circle -->
        <View
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_empty_state_challenges" />

        <!-- Trophy Stack -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="-8dp"
                android:alpha="0.6"
                android:rotation="-15"
                android:src="@drawable/ic_trophy"
                app:tint="@color/silver"
                android:contentDescription="@null" />

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:elevation="4dp"
                android:src="@drawable/ic_trophy"
                app:tint="@color/gold"
                android:contentDescription="@string/empty_challenges_title" />

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="-8dp"
                android:alpha="0.6"
                android:rotation="15"
                android:src="@drawable/ic_trophy"
                app:tint="@color/bronze"
                android:contentDescription="@null" />

        </LinearLayout>

    </FrameLayout>

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:gravity="center"
        android:text="@string/empty_challenges_title"
        android:textColor="@color/text_primary"
        android:textSize="22sp"
        android:textStyle="bold" />

    <!-- Description -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:paddingHorizontal="16dp"
        android:text="@string/empty_challenges_message"
        android:textColor="@color/text_secondary"
        android:textSize="15sp" />

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- Browse Challenges -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_browse_challenges"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:paddingHorizontal="20dp"
            android:text="@string/empty_challenges_cta"
            android:textAllCaps="false"
            android:textSize="14sp"
            app:backgroundTint="@color/primary"
            app:cornerRadius="24dp"
            app:icon="@drawable/ic_search"
            app:iconGravity="textStart"
            app:iconPadding="8dp" />

        <!-- Create Challenge -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_create_challenge"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:paddingHorizontal="20dp"
            android:text="@string/create_challenge"
            android:textAllCaps="false"
            android:textColor="@color/primary"
            android:textSize="14sp"
            app:cornerRadius="24dp"
            app:icon="@drawable/ic_add"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconTint="@color/primary"
            app:strokeColor="@color/primary" />

    </LinearLayout>

    <!-- Challenge Types Preview -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- Distance Challenge -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_challenge_type_distance">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_distance"
                    app:tint="@color/stat_distance"
                    android:contentDescription="@null" />

            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/distance"
                android:textColor="@color/text_hint"
                android:textSize="11sp" />

        </LinearLayout>

        <!-- Duration Challenge -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_challenge_type_duration">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_duration"
                    app:tint="@color/stat_duration"
                    android:contentDescription="@null" />

            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/duration"
                android:textColor="@color/text_hint"
                android:textSize="11sp" />

        </LinearLayout>

        <!-- Calories Challenge -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_challenge_type_calories">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_calories"
                    app:tint="@color/stat_calories"
                    android:contentDescription="@null" />

            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/calories"
                android:textColor="@color/text_hint"
                android:textSize="11sp" />

        </LinearLayout>

        <!-- Steps Challenge -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_challenge_type_steps">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_walking"
                    app:tint="@color/stat_steps"
                    android:contentDescription="@null" />

            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/steps"
                android:textColor="@color/text_hint"
                android:textSize="11sp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
